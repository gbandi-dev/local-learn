# Re:Earth CMS credentials for write access
# Copy this file to .env and fill in your values
# Get these from your Re:Earth CMS instance → Settings

# API token (Settings → API → Create token)
VITE_REEARTH_API_TOKEN=

# Project ID (Settings → General → Project ID)
VITE_REEARTH_PROJECT_ID=

# Model IDs (Settings → Schema → click a model → copy its ID)
VITE_REEARTH_SPOTS_MODEL_ID=
VITE_REEARTH_MENTORS_MODEL_ID=
